# ── LLM Provider ─────────────────────────────────────────────────────────────
# Groq gives us Llama 3.3 70B for free tier — fast inference, good for evals
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Observability ─────────────────────────────────────────────────────────────
# LangSmith traces every LLM call — critical for debugging RAG failures
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=verirag-prod

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg requires postgresql+asyncpg:// scheme (not plain postgresql://)
DATABASE_URL=postgresql+asyncpg://verirag:verirag_secret@localhost:5432/verirag

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Running chroma in-process (no separate server needed for dev)
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=verirag_docs

# ── Embeddings ────────────────────────────────────────────────────────────────
# Using local model — no API key needed, runs on CPU fine for this scale
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── RAG Pipeline ─────────────────────────────────────────────────────────────
# MMR (max marginal relevance) balances relevance vs diversity in retrieval
RETRIEVAL_TOP_K=5
RETRIEVAL_LAMBDA=0.5           # MMR lambda: 0=max diversity, 1=max relevance

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
LOG_LEVEL=DEBUG
API_V1_PREFIX=/api/v1
